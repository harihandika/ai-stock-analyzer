# =============================================================
# AI Stock Analyzer - Environment Variables Template
# Salin file ini menjadi .env dan isi nilainya sesuai environment Anda.
# JANGAN commit file .env ke Git!
# =============================================================

# -------------------------
# APPLICATION
# -------------------------
APP_NAME="AI Stock Analyzer"
APP_ENV="development"  # development | production
DEBUG=True

# -------------------------
# DATABASE (PostgreSQL)
# -------------------------
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/ai_stock_analyzer_db

# Untuk Alembic (sync driver, tidak ada asyncpg)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/ai_stock_analyzer_db

# Jika menggunakan Supabase, URL bisa dilihat di Settings > Database > Connection string
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# -------------------------
# SECURITY (JWT)
# -------------------------
# Generate secret key dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 jam

# -------------------------
# ANTHROPIC (Claude AI)
# -------------------------
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_api_key_here
AI_MODEL_OPERATIONAL=claude-sonnet-4-6    # Digunakan untuk analisis harian
AI_MODEL_STRATEGIC=claude-opus-4-6        # Digunakan untuk evaluasi prompt

# -------------------------
# REDIS (Celery Broker & Cache)
# -------------------------
# Local Redis (via Docker): redis://localhost:6379/0
# Upstash Redis: redis://default:[password]@[host]:6379
REDIS_URL=redis://localhost:6379/0

# -------------------------
# MARKET DATA
# -------------------------
# Default: yfinance (gratis, tidak perlu API key)
# Jika menggunakan Alpaca, isi API key berikut:
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# -------------------------
# CORS (Untuk Frontend)
# -------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
